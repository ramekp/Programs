void SystemClock_Config(void) {
	RCC_OscInitTypeDef RCC_OscInitStruct = {0};
	RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};
	HAL_PWREx_ControlVoltageScaling(PWR_REGULATOR_VOLTAGE_SCALE1);
	RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
	RCC_OscInitStruct.HSIState = RCC_HSI_ON;
	RCC_OscInitStruct.HSIDiv = RCC_HSI_DIV1;
	RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
	RCC_OscInitStruct.PLL.PLLState = RCC_PLL_NONE;
	if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) {
		Error_Handler();
	}
	RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                              |RCC_CLOCKTYPE_PCLK1;
	RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_HSI;
	RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
	RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;
	if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_0) != HAL_OK) {
		Error_Handler();
	}
}

static void uart2_print(const char* s) {
    HAL_UART_Transmit(&huart2, (uint8_t*)s, (uint16_t)strlen(s), 50U);
}

static void uart6_receive() {
	uint8_t buffer[5];
	uint8_t index = 0;
	bool message_complete = false;
	uint32_t timeout_counter = 0;
	const uint32_t MAX_TIMEOUT = 1000;
	memset(buffer, 0, sizeof(buffer));
	while (index < (sizeof(buffer) - 1) && !message_complete && timeout_counter < MAX_TIMEOUT) {
		if (HAL_UART_Receive(&huart6, &buffer[index], 1, 10) == HAL_OK) {
			if (buffer[index] == '\r') {
				message_complete = true;
			}
			index++;
			timeout_counter = 0;
		}
		else {
			timeout_counter++;
			HAL_Delay(1);
		}
	}
	buffer[index] = '\0';
	if (message_complete) {
		uint8_t message_length = 0;
		while (buffer[message_length] != '\n' && buffer[message_length] != '\r' && buffer[message_length] != '\0') {
			message_length++;
		}
		uart2_print("Received: ");
		HAL_UART_Transmit(&huart2, buffer, message_length, 100);
		uart2_print("\n\r");
	}
	else if (timeout_counter >= MAX_TIMEOUT) {
		uart2_print("Receive timeout\n\r");
	}
}

static void uart4_print(const char* s) {
    HAL_UART_Transmit(&huart4, (uint8_t*)s, (uint16_t)strlen(s), 50U);
}

int main(void) {
	HAL_Init();
	SystemClock_Config();
	MX_GPIO_Init();
	MX_USART2_UART_Init();
	MX_USART4_UART_Init();
	MX_USART6_UART_Init();
	uart2_print("WELCOME BOARD 1\n\r");
	while (1) {
		uart4_print("hi\n\r");
		HAL_Delay(10);
	}
}

