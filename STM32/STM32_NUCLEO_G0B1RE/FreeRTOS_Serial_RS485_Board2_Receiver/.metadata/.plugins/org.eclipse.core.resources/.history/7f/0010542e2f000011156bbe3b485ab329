  if (huart->Instance == USART4) {
    if (rx4_byte == '\r') {
    }
    else if (rx4_byte == '\n') {
      rx4_buffer[rx4_index] = '\0';   // terminate string
      rx4_index = 0;
      msg_ready = 1;                  // notify main/task
    }
    else {
      if (rx4_index < sizeof(rx4_buffer) - 1) {
        rx4_buffer[rx4_index++] = rx4_byte;
      }
    }
  HAL_UART_Receive_IT(&huart4, &rx4_byte, 1);
  }
}
