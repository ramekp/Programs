/**
 * @file main.c
 * @brief STM32 + CMSIS-RTOS v2 app using UART4 (RX via interrupts) and UART2 (debug TX),
 *        with three RTOS tasks and simple newline-terminated command parsing.
 *
 * Overview:
 *  - UART4: interrupt-driven RX (1 byte), assembles text into a small buffer
 *           until '\n' is received. '\r' is ignored. On newline, sets msg_ready.
 *  - UART2: debug/console TX (prints welcome and responses).
 *  - Tasks:
 *      * defaultTask: idle loop placeholder
 *      * LEDTask:     placeholder for LED control
 *      * SerialTask:  checks msg_ready, compares command, sends response over UART2
 *
 * Notes:
 *  - rx4_buffer is limited to 10 chars. Excess characters (if any) are ignored
 *    once the buffer is nearly full (keeps room for '\0').
 *  - Cross-context communication (ISR -> task) is done via a volatile flag (msg_ready).
 *  - System clock uses HSI (no PLL), Flash latency 0.
 */

#include "main.h"        // HAL and board-specific definitions
#include "cmsis_os.h"    // CMSIS-RTOS v2 API
#include <string.h>      // For strlen(), strcmp(), memset()

/* =========================== RX state (UART4) =========================== */
uint8_t rx4_byte;               // Single-byte staging area for UART4 RX (IT mode)
char rx4_buffer[10];            // Small command buffer for UART4 (NUL-terminated)
volatile uint8_t rx4_index = 0; // Current write index into rx4_buffer
volatile uint8_t msg_ready = 0; // Flag set when a complete line is received

/* =============================== UARTs ================================= */
UART_HandleTypeDef huart2;      // UART2 handle (debug/console)
UART_HandleTypeDef huart4;      // UART4 handle (command input)

/* ============================= RTOS objects ============================= */
osThreadId_t defaultTaskHandle; // Default/idle-like task handle
const osThreadAttr_t defaultTask_attributes = {
  .name = "defaultTask",                      // Task name (for debug)
  .priority = (osPriority_t) osPriorityNormal,// Normal priority
  .stack_size = 128 * 4                       // Stack size in bytes
};

osThreadId_t LEDTaskHandle;     // LED task handle
const osThreadAttr_t LEDTask_attributes = {
  .name = "LEDTask",                          // Task name (for debug)
  .priority = (osPriority_t) osPriorityNormal,// Normal priority
  .stack_size = 128 * 4                       // Stack size in bytes
};

osThreadId_t SerialTaskHandle;  // Serial processing task handle
const osThreadAttr_t SerialTask_attributes = {
  .name = "SerialTask",                       // Task name (for debug)
  .priority = (osPriority_t) osPriorityNormal,// Normal priority
  .stack_size = 128 * 4                       // Stack size in bytes
};

