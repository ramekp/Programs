/**
 * @brief Default RTOS task. Placeholder loop with minimal delay.
 *
 * Behavior:
 *  - Runs forever, sleeping 1 ms per iteration to yield CPU.
 *
 * @param argument Unused (pass NULL).
 */
void StartDefaultTask(void *argument) {
  for(;;) {                // Infinite loop
    osDelay(1);            // Yield for 1 ms
  }
}

/**
 * @brief LED control task (placeholder).
 *
 * Behavior:
 *  - Runs forever, currently sleeping 1 ms per iteration.
 *  - Intended place to add LED blinking/timing logic.
 *
 * @param argument Unused (pass NULL).
 */
void LEDTaskFunction(void *argument) {
  for(;;) {                // Infinite loop
    osDelay(1);            // Yield for 1 ms
  }
}

/**
 * @brief Serial processing task. Reacts to messages assembled by UART4 ISR.
 *
 * Behavior:
 *  - Polls msg_ready flag; when set, clears it and parses rx4_buffer.
 *  - If command == "hi", responds "ok\r\n" over UART2.
 *  - Clears rx4_buffer after processing to avoid stale data.
 *  - Sleeps 5 ms per loop to avoid CPU hogging.
 *
 * Notes:
 *  - msg_ready is set in ISR; declared volatile to ensure visibility.
 *  - strcmp() is safe because ISR ensures rx4_buffer is NUL-terminated.
 *
 * @param argument Unused (pass NULL).
 */
void SerialTaskFunction(void *argument) {
  for (;;) {                               // Infinite processing loop
    if (msg_ready) {                       // Check if a new message is ready
      msg_ready = 0;                       // Consume the message (clear flag)

      if (strcmp(rx4_buffer, "hi") == 0) { // If command is exactly "hi"
        char response[] = "ok\r\n";        // Prepare response
        HAL_UART_Transmit(&huart2, (uint8_t *)response, strlen(response), HAL_MAX_DELAY); // Send via UART2
      }

      memset(rx4_buffer, 0, sizeof(rx4_buffer)); // Clear buffer content
    }

    osDelay(5);                            // Small sleep to yield CPU
  }
}

/**
 * @brief Program entry point. Initializes HAL, clocks, GPIO, UARTs, and RTOS.
 *
 * Flow:
 *  - HAL_Init() to reset peripherals and init the HAL.
 *  - Configure system clock via HSI (no PLL).
 *  - Initialize GPIO and both UARTs.
 *  - Start interrupt-driven RX on UART4 (1 byte).
 *  - Transmit a welcome string over UART2.
 *  - Initialize and start the RTOS kernel with three tasks.
 *  - Infinite loop (should not be reached after osKernelStart()).
 */
int main(void) {
  HAL_Init();                      // Initialize the HAL library and low-level hardware
  SystemClock_Config();            // Configure system clock (HSI, no PLL)

  MX_GPIO_Init();                  // Initialize GPIOs (LED + user button)
  MX_USART2_UART_Init();           // Initialize UART2 (debug/console)
  MX_USART4_UART_Init();           // Initialize UART4 (command input)

  // Start interrupt-driven reception on UART4 (1 byte at a time)
  HAL_UART_Receive_IT(&huart4, &rx4_byte, 1);

  // Transmit a welcome banner over UART2
  char wel_msg[] = "Welcome \r\n";                                           // Text to send
  HAL_UART_Transmit(&huart2, (uint8_t *)wel_msg, strlen(wel_msg), HAL_MAX_DELAY); // Send via UART2, Block until done

  osKernelInitialize();           // Initialize CMSIS-RTOS2 kernel objects

  // Create RTOS tasks
  defaultTaskHandle = osThreadNew(StartDefaultTask, NULL, &defaultTask_attributes);
  LEDTaskHandle     = osThreadNew(LEDTaskFunction,   NULL, &LEDTask_attributes);
  SerialTaskHandle  = osThreadNew(SerialTaskFunction,NULL, &SerialTask_attributes);

  osKernelStart();                 // Start the RTOS scheduler (control moves to tasks)

  while (1) {
    // Should not reach here once the scheduler is running
  }
}

/**
 * @brief UART RX complete callback (ISR context).
 *
 * Behavior (only for UART4):
 *  - On '\r': ignore (do nothing).
 *  - On '\n': terminate the buffer with '\0', reset index, set msg_ready flag.
 *  - Otherwise: append the byte to rx4_buffer if space remains.
 *  - Always restarts the 1-byte IT receive.
 *
 * @param huart Pointer to the UART handle that triggered the callback.
 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
  if (huart->Instance == USART4) {                // Ensure this is UART4's interrupt

    if (rx4_byte == '\r') {
      // Ignore carriage return (no action)
    }
    else if (rx4_byte == '\n') {                  // Line-feed marks end of message
      rx4_buffer[rx4_index] = '\0';               // NUL-terminate the string
      rx4_index = 0;                              // Reset write index for next message
      msg_ready = 1;                              // Notify task layer that a message is ready
    }
    else {
      // Store character if there’s room (reserve 1 byte for the final '\0')
      if (rx4_index < sizeof(rx4_buffer) - 1) {
        rx4_buffer[rx4_index++] = rx4_byte;       // Append to buffer and advance index
      }
      // If full, the byte is dropped; buffer remains valid and NUL-terminable on '\n'
    }

    // Re-arm interrupt-driven RX for the next byte
    HAL_UART_Receive_IT(&huart4, &rx4_byte, 1);
  }
}

/**
 * @brief Period elapsed callback for TIM base. Used to increment HAL tick.
 *
 * Behavior:
 *  - If the timer instance is TIM6, call HAL_IncTick().
 *  - This provides a time base for HAL timing functions when TIM6 is configured.
 *
 * @param htim Pointer to a TIM handle that triggered the callback.
 */
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
  if (htim->Instance == TIM6) {    // Check the timer instance
    HAL_IncTick();                 // Increment HAL time base tick
  }
}

/**
 * @brief Fatal error handler. Disables interrupts and traps the CPU.
 *
 * Behavior:
 *  - __disable_irq() to prevent further interrupts.
 *  - Infinite loop to halt execution for debugging.
 */
void Error_Handler(void) {
  __disable_irq();                 // Disable all interrupts
  while (1) {                      // Trap CPU here
  }
}

