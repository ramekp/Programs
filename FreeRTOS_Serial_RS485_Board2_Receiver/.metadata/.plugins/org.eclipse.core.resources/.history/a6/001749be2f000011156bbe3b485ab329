/**
 * @brief Default FreeRTOS Task
 */
void StartDefaultTask(void *argument) {
  for (;;) {
    osDelay(1);
  }
}


/**
 * @brief LED Task (currently empty)
 */
void LEDTaskFunction(void *argument) {
  for (;;) {
    osDelay(1);
  }
}


/**
 * @brief Serial processing task.
 *        Executes when msg_ready flag is set by UART ISR.
 */
void SerialTaskFunction(void *argument) {
  for (;;) {

    if (msg_ready) {           // New message received
      msg_ready = 0;

      if (strcmp(rx4_buffer, "hi") == 0) { // Compare with expected command
        char response[] = "ok\r\n";
        HAL_UART_Transmit(&huart2, (uint8_t *)response, strlen(response), HAL_MAX_DELAY);
      }

      memset(rx4_buffer, 0, sizeof(rx4_buffer)); // Clear buffer
    }

    osDelay(5); // Avoid CPU hogging
  }
}


void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
  if (htim->Instance == TIM6) {
    HAL_IncTick(); // SysTick increment
  }
}


/**
 * @brief Error handler
 */
void Error_Handler(void) {
  __disable_irq();
  while (1) {}
}

