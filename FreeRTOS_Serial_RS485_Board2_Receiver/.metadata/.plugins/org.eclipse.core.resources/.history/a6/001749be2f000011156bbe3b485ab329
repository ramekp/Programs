/**
 * @file main.c
 * @brief STM32 FreeRTOS project that handles UART4 interrupt-based input,
 *        echoes specific commands through UART2, and runs multiple RTOS tasks.
 *
 * UART4:
 *   - Receives characters interrupt-driven
 *   - Forms messages ending with '\n'
 *   - Notifies SerialTask when a command is ready
 *
 * UART2:
 *   - Used for debug output (115200 baud)
 *
 * Tasks:
 *   - DefaultTask: Idle loop
 *   - LEDTask: Reserved for LED-related controls
 *   - SerialTask: Processes received UART commands
 */

#include "main.h"
#include "cmsis_os.h"
#include <string.h>

/* ----------- UART receive globals ----------- */
uint8_t rx4_byte;               // Single received byte
char rx4_buffer[10];            // Buffer for incoming commands
volatile uint8_t rx4_index = 0; // Current buffer index
volatile uint8_t msg_ready = 0; // Flag set when full command received

UART_HandleTypeDef huart2;      // UART2 handle
UART_HandleTypeDef huart4;      // UART4 handle

/* ----------- FreeRTOS Thread Handles ----------- */
osThreadId_t defaultTaskHandle;
const osThreadAttr_t defaultTask_attributes = {
  .name = "defaultTask",
  .priority = (osPriority_t) osPriorityNormal,
  .stack_size = 128 * 4
};

osThreadId_t LEDTaskHandle;
const osThreadAttr_t LEDTask_attributes = {
  .name = "LEDTask",
  .priority = (osPriority_t) osPriorityNormal,
  .stack_size = 128 * 4
};

osThreadId_t SerialTaskHandle;
const osThreadAttr_t SerialTask_attributes = {
  .name = "SerialTask",
  .priority = (osPriority_t) osPriorityNormal,
  .stack_size = 128 * 4
};

/* Function prototypes */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_USART4_UART_Init(void);
void StartDefaultTask(void *argument);
void LEDTaskFunction(void *argument);
void SerialTaskFunction(void *argument);


int main(void) {
  HAL_Init();                   // Initialize HAL and system peripherals
  SystemClock_Config();         // Configure clock and PLL
  MX_GPIO_Init();               // Initialize GPIO pins
  MX_USART2_UART_Init();        // Init UART2 for debugging
  MX_USART4_UART_Init();        // Init UART4 for command reception

  // Start UART4 interrupt receiving for 1 byte at a time
  HAL_UART_Receive_IT(&huart4, &rx4_byte, 1);

  // Print welcome message over UART2
  char wel_msg[] = "Welcome12\r\n";
  HAL_UART_Transmit(&huart2, (uint8_t *)wel_msg, strlen(wel_msg), HAL_MAX_DELAY);

  // Initialize FreeRTOS kernel
  osKernelInitialize();

  // Create the tasks
  defaultTaskHandle = osThreadNew(StartDefaultTask, NULL, &defaultTask_attributes);
  LEDTaskHandle = osThreadNew(LEDTaskFunction, NULL, &LEDTask_attributes);
  SerialTaskHandle = osThreadNew(SerialTaskFunction, NULL, &SerialTask_attributes);

  // Start RTOS
  osKernelStart();

  while (1) {
    // Should never reach here after RTOS starts
  }
}


/**
 * @brief UART Receive Complete ISR callback
 *        Called automatically when 1 byte is received on UART4.
 *
 * @param huart Pointer to UART handle
 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {

  if (huart->Instance == USART4) {       // Ensure interrupt is from UART4

    if (rx4_byte == '\r') {
      // Ignore carriage return
    }
    else if (rx4_byte == '\n') {         // Message end detected
      rx4_buffer[rx4_index] = '\0';      // Null-terminate string
      rx4_index = 0;                     // Reset buffer index
      msg_ready = 1;                     // Signal to SerialTask
    }
    else {
      // Store character if buffer has space
      if (rx4_index < sizeof(rx4_buffer) - 1)
        rx4_buffer[rx4_index++] = rx4_byte;
    }

    // Restart UART interrupt reception
    HAL_UART_Receive_IT(&huart4, &rx4_byte, 1);
  }
}


