static void MX_USART2_UART_Init(void) {
    huart2.Instance = USART2;
    huart2.Init.BaudRate = 115200;
    huart2.Init.WordLength = UART_WORDLENGTH_8B;
    huart2.Init.StopBits = UART_STOPBITS_1;
    huart2.Init.Parity = UART_PARITY_NONE;
    huart2.Init.Mode = UART_MODE_TX_RX;
    huart2.Init.HwFlowCtl = UART_HWCONTROL_NONE;
    huart2.Init.OverSampling = UART_OVERSAMPLING_16;
    huart2.Init.OneBitSampling = UART_ONE_BIT_SAMPLE_DISABLE;
    HAL_UART_Transmit(&huart2, (uint8_t*)s, (uint16_t)strlen(s), 50U);
}

static void log_frame(const char* prefix, uint8_t digit) {
    char buf[7];
    buf[0] = '*';
    buf[1] = (char)('0' + digit);
    buf[2] = '#';
    buf[3] = '\r';
    buf[4] = '\n';

    log_prefix(prefix);
    HAL_UART_Transmit(&huart2, (uint8_t*)buf, 5, 50U);
}

static bool uart4_get_byte(uint8_t *b) {
    if (HAL_UART_Receive(&huart4, b, 1, 10U) == HAL_OK) {
        return true;
    }
    led_task_500ms();
    return false;
}

static bool UART4_WaitFor_Frame_StarDigitHash(uint8_t *out_digit) {
    enum { S_WAIT_STAR, S_GET_DIGIT, S_WAIT_HASH, S_EAT_EOL } state = S_WAIT_STAR;
    uint8_t ch = 0;

    for (;;) {
        if (!uart4_get_byte(&ch)) {
            continue;
        }

        switch (state) {
            case S_WAIT_STAR:
                if (ch == '*') {
                    state = S_GET_DIGIT;
                }
                break;

            case S_GET_DIGIT:
                if (ch >= '0' && ch <= '9') {
                    *out_digit = (uint8_t)(ch - '0');
                    state = S_WAIT_HASH;
                } else {
                    state = (ch == '*') ? S_GET_DIGIT : S_WAIT_STAR;
                }
                break;

            case S_WAIT_HASH:
                if (ch == '#') {
                    state = S_EAT_EOL;
                } else {
                    state = (ch == '*') ? S_GET_DIGIT : S_WAIT_STAR;
                }
                break;

            case S_EAT_EOL:
                HAL_Delay(100U);
                if (ch == '\r' || ch == '\n') {
                    uint8_t c2;
                    (void)HAL_UART_Receive(&huart4, &c2, 1, 0U);
                }
                return true;
        }

        led_task_500ms();
    }
}

static bool compute_reply(uint8_t in_digit, uint8_t *out_digit) {
    if ((in_digit % 2U) == 0U && in_digit <= 8U) {
        *out_digit = (uint8_t)(in_digit + 1U);
        return true;
    }
    return false;
}

int main(void) {
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_USART4_UART_Init();
    MX_USART2_UART_Init();

    log_prefix("Board2 ready\r\n");

    for (;;) {
        uint8_t rx_digit = 0xFF;

        if (UART4_WaitFor_Frame_StarDigitHash(&rx_digit)) {
            log_frame("RX4: ", rx_digit);

            uint8_t tx_digit = 0xFF;
            if (compute_reply(rx_digit, &tx_digit)) {
                char resp[6];
                resp[0] = '*';
                resp[1] = (char)('0' + tx_digit);
                resp[2] = '#';
                resp[3] = '\r';
                resp[4] = '\n';

                HAL_UART_Transmit(&huart4, (uint8_t*)resp, 5, 50U);
                log_frame("TX4: ", tx_digit);
            } else {
                log_prefix("RX4: unexpected digit\r\n");
            }
        }

        led_task_500ms();
    }
}

void Error_Handler(void) {
    __disable_irq();
    while (1) {
        HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
        HAL_Delay(100U);
    }
}

